# Code-signing configuration for `make release` — copy to signing.env and fill in.
# signing.env is gitignored; never commit real identity values.
#
#   DEVELOPMENT_TEAM     Apple Developer Team ID (10 chars), e.g. ABCDE12345
#   SIGN_IDENTITY        Full "Developer ID Application: NAME (TEAMID)" string
#   NOTARY_PROFILE_NAME  notarytool keychain profile (xcrun notarytool store-credentials)
DEVELOPMENT_TEAM=
SIGN_IDENTITY=
NOTARY_PROFILE_NAME=
